#!/bin/sh
. ./tconf.sh

tconf_init "$@"

tconf_search_cc "$HOST"
tconf_require "C compiler" "$CC"
tconf_find_os
tconf_require_header "$CC" stdio.h
tconf_require_header "$CC" stdlib.h
tconf_require_header "$CC" stddef.h
tconf_require_header "$CC" stdarg.h
tconf_require_header "$CC" ctype.h
tconf_require_header "$CC" string.h
tconf_require_header "$CC" sys/wait.h
tconf_require_header "$CC" unistd.h
tconf_require_header "$CC" fcntl.h
tconf_check_header "$CC" termios.h
tconf_check_header "$CC" signal.h
tconf_check_header "$CC" dirent.h
tconf_check_header "$CC" time.h
tconf_check_header "$CC" sys/ioctl.h
tconf_check_header "$CC" sys/stat.h

# check some functions
tconf_check_func "$CC" "unistd.h" "pipe"
tconf_check_func "$CC" "unistd.h" "isatty"
tconf_check_func "$CC" "fcntl.h" "fcntl"

tconf_fini
exit 0
